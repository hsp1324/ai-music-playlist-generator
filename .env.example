AIMP_ENVIRONMENT=development
AIMP_DEBUG=true
AIMP_API_PREFIX=/api
AIMP_DATABASE_URL=sqlite:///./storage/app.db

AIMP_STORAGE_ROOT=storage
AIMP_FFMPEG_BINARY=ffmpeg
AIMP_FFMPEG_STALL_TIMEOUT_SECONDS=900
AIMP_PLAYLIST_TARGET_MINUTES=60
AIMP_CROSSFADE_SECONDS=2.0

AIMP_SLACK_SIGNING_SECRET=
AIMP_SLACK_BOT_TOKEN=
AIMP_SLACK_APP_TOKEN=
AIMP_SLACK_CLIENT_ID=
AIMP_SLACK_CLIENT_SECRET=
AIMP_SLACK_REDIRECT_URI=
AIMP_SLACK_SCOPES=app_mentions:read,channels:history,channels:read,chat:write,commands,files:write,im:history,im:read,im:write,users:read
AIMP_SLACK_USER_SCOPES=
AIMP_SLACK_REVIEW_CHANNEL_ID=
AIMP_SLACK_ENABLE_SIGNATURE_VERIFICATION=false
AIMP_PUBLIC_BASE_URL=http://127.0.0.1:8000

AIMP_AUTO_APPROVAL_MODE=human
AIMP_MCP_AGENT_NAME=approval-agent
AIMP_MCP_REVIEW_POLICY=Approve only high-confidence tracks that match channel style, reject low-quality outputs, hold uncertain cases.
AIMP_MCP_REVIEW_URL=
AIMP_MCP_API_KEY=
AIMP_MCP_TIMEOUT_SECONDS=15
AIMP_MCP_FALLBACK_TO_RULES=true

AIMP_SUNO_API_BASE_URL=https://api.sunoapi.org
AIMP_SUNO_API_KEY=
AIMP_SUNO_DEFAULT_MODEL=V5_5
AIMP_SUNO_PROVIDER_MODE=manual_webhook
AIMP_SUNO_WEBHOOK_SECRET=
AIMP_SUNO_BROWSER_LOGIN_URL=https://suno.com/create
AIMP_SUNO_BROWSER_NAME=chromium
AIMP_SUNO_BROWSER_EXECUTABLE_PATH=
AIMP_SUNO_SESSION_STALE_HOURS=72

AIMP_AUTO_BUILD_PLAYLISTS=true
AIMP_AUTO_BUILD_RENDER_AUDIO=true
AIMP_AUTO_BUILD_TITLE_PREFIX=Auto Playlist

AIMP_YOUTUBE_CLIENT_SECRETS_PATH=
AIMP_YOUTUBE_OAUTH_REDIRECT_URI=
AIMP_YOUTUBE_PRIVACY_STATUS=private
AIMP_YOUTUBE_CATEGORY_ID=10
AIMP_YOUTUBE_CONTAINS_SYNTHETIC_MEDIA=false
AIMP_YOUTUBE_AUTO_UPLOAD_ON_PUBLISH=true
AIMP_YOUTUBE_TITLE_SUFFIX=Official AI Visualizer
AIMP_YOUTUBE_DEFAULT_HASHTAGS=#aimusic #visualizer #electronicmusic

AIMP_DREAMINA_PROVIDER_MODE=disabled
AIMP_DREAMINA_API_BASE_URL=https://api.useapi.net/v1/dreamina
AIMP_DREAMINA_API_TOKEN=
AIMP_DREAMINA_ACCOUNT=
AIMP_DREAMINA_VIDEO_MODEL=seedance-1.5-pro
AIMP_DREAMINA_VIDEO_DURATION_SECONDS=8
AIMP_DREAMINA_VIDEO_RATIO=16:9
AIMP_DREAMINA_POLL_INTERVAL_SECONDS=10
AIMP_DREAMINA_TIMEOUT_SECONDS=240

AIMP_WORKER_AUTOSTART=true
AIMP_WORKER_POLL_INTERVAL_SECONDS=2.0
